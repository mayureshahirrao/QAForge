# QAForge environment variables — copy to `.env` and fill in.
QAFORGE_ENV=dev
QAFORGE_LOG_LEVEL=INFO
# Optional deterministic Faker seed
# QAFORGE_FAKER_SEED=42

# OAuth (client_credentials)
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Databases
PG_USER=qa
PG_PASSWORD=
MYSQL_USER=qa
MYSQL_PASSWORD=
MONGO_URI=mongodb://localhost:27017

# AI providers
OPENAI_API_KEY=
